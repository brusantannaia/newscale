<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Proposta — Stoller do Brasil · NewScale Consulting</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<style>
:root {
  --ink:#14373C; --ink2:#1a4449; --sage:#435D51;
  --terra:#B06E4A; --tl:#c4835e; --sand:#A38362;
  --cream:#E8E6E0; --cl:#F4F3EF; --white:#FAFAF8;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--ink);-webkit-font-smoothing:antialiased}

@keyframes fadeUp{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
@keyframes pulse{0%,100%{opacity:.45;transform:scale(1)}50%{opacity:.95;transform:scale(1.07)}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}

.reveal{opacity:0;transform:translateY(32px);transition:opacity .75s ease,transform .75s ease}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}.rd4{transition-delay:.4s}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:16px 48px;background:rgba(20,55,60,.93);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.05)}
.nav-logo img{height:26px}
.nav-tag{font-size:.6rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--terra)}

/* HERO */
.hero{min-height:100vh;background:linear-gradient(145deg,#0b2124 0%,#14373C 38%,#1c4840 72%,#435D51 100%);display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:110px 40px 90px;position:relative;overflow:hidden}
.hero-topo{position:absolute;inset:0;opacity:.07;pointer-events:none}
.hero-topo svg{width:100%;height:100%}
.hero-grain{position:absolute;inset:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.025}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(176,110,74,.12);border:1px solid rgba(176,110,74,.22);border-radius:40px;padding:6px 20px;margin-bottom:28px;font-size:.71rem;font-weight:600;color:rgba(255,255,255,.65);letter-spacing:.08em;animation:fadeUp .8s ease .1s both}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--terra);animation:pulse 2s ease infinite}
.hero-eyebrow{font-size:.67rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--terra);margin-bottom:20px;animation:fadeUp .8s ease .25s both}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4.4rem);font-weight:700;color:#fff;line-height:1.1;max-width:880px;margin:0 auto 26px;animation:fadeUp .9s ease .4s both}
.hero h1 em{font-style:italic;color:var(--tl)}
.hero-sub{font-size:clamp(.9rem,1.5vw,1.05rem);color:rgba(255,255,255,.55);font-weight:300;max-width:600px;margin:0 auto 56px;line-height:1.78;animation:fadeUp .9s ease .6s both}
.hero-scroll{display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none;animation:fadeUp .9s ease .8s both}
.hero-scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--terra),transparent)}
.hero-scroll-label{font-size:.61rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.3)}

/* SECTIONS */
section{padding:100px 48px}
.container{max-width:1160px;margin:0 auto}
.section-label{font-size:.63rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--terra);margin-bottom:14px}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.85rem,3.2vw,2.7rem);font-weight:700;color:var(--ink);line-height:1.16}
.section-title em{font-style:italic;color:var(--terra)}
.section-title.light{color:#fff}

/* CONTEXTO */
.ctx-section{background:var(--cl)}
.ctx-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start}
.ctx-text p{font-size:.94rem;color:#2C4A4E;line-height:1.82;margin-bottom:20px;font-weight:300}
.ctx-text p strong{font-weight:600;color:var(--ink)}
.ctx-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.stat-card{border-radius:14px;padding:28px 24px}
.stat-card:nth-child(1){background:var(--ink)}.stat-card:nth-child(2){background:var(--terra)}
.stat-card:nth-child(3){background:var(--sage)}.stat-card:nth-child(4){background:#1C3E43}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:700;color:rgba(255,255,255,.95);line-height:1;margin-bottom:8px}
.stat-lbl{font-size:.67rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.5)}

/* DORES */
.dores-section{background:var(--ink)}
.dores-section .section-title{color:#fff}
.dores-section .section-label{color:var(--tl)}
.dores-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:52px}
.dore-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:32px 28px;transition:border-color .3s,background .3s}
.dore-card:hover{border-color:rgba(176,110,74,.3);background:rgba(176,110,74,.05)}
.dore-card.wide{grid-column:span 2}
.dore-num{font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:700;color:rgba(176,110,74,.12);line-height:1;margin-bottom:14px}
.dore-title{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--tl);margin-bottom:12px}
.dore-text{font-size:.86rem;color:rgba(255,255,255,.58);line-height:1.76;font-weight:300}

/* PROGRAMAS */
.prog-section{background:var(--white)}
.prog-header{margin-bottom:52px}
.adapt-banner{display:flex;align-items:flex-start;gap:16px;background:rgba(176,110,74,.07);border:1px solid rgba(176,110,74,.18);border-left:3px solid var(--terra);border-radius:0 12px 12px 0;padding:22px 28px;margin-bottom:52px}
.adapt-banner-icon{font-size:1.3rem;flex-shrink:0;margin-top:2px}
.adapt-banner-title{font-size:.84rem;font-weight:700;color:var(--ink);margin-bottom:6px}
.adapt-banner-text{font-size:.82rem;color:#4a6a6e;line-height:1.72;font-weight:300}
.adapt-banner-text strong{font-weight:600;color:var(--ink)}
.fase-block{margin-bottom:32px}
.fase-hdr{display:flex;justify-content:space-between;align-items:center;padding:26px 34px;border-radius:14px 14px 0 0}
.fase-hdr.c1{background:var(--ink)}.fase-hdr.c2{background:var(--terra)}
.fase-tag{font-size:.61rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.5);margin-bottom:6px}
.fase-name{font-family:'Cormorant Garamond',serif;font-size:1.55rem;font-weight:700;color:#fff;line-height:1.15}
.fase-dur{font-size:.72rem;color:rgba(255,255,255,.45);margin-top:4px}
.fase-badge{width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:rgba(255,255,255,.65);flex-shrink:0}
.fase-body{background:var(--cl);border-radius:0 0 14px 14px;padding:36px;margin-top:1px}
.fase-body-intro{font-size:.93rem;color:#2C4A4E;line-height:1.78;font-weight:300;margin-bottom:28px}
.fase-body-intro strong{font-weight:600;color:var(--ink)}
.blocos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.bloco{background:var(--white);border:1px solid rgba(20,55,60,.08);border-radius:12px;padding:24px 20px;transition:border-color .25s,box-shadow .25s}
.bloco:hover{border-color:rgba(176,110,74,.2);box-shadow:0 6px 20px rgba(20,55,60,.07)}
.bloco-ico{font-size:1.3rem;margin-bottom:12px}
.bloco-lbl{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--terra);margin-bottom:5px}
.bloco-title{font-size:.9rem;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:8px}
.bloco-text{font-size:.79rem;color:#4a6a6e;line-height:1.66;font-weight:300}

/* GPT */
.gpt-section{background:linear-gradient(135deg,#081e22 0%,#0f2d32 30%,#14373C 60%,#1a4035 100%);position:relative;overflow:hidden}
.gpt-topo{position:absolute;inset:0;opacity:.08;pointer-events:none}
.gpt-topo svg{width:100%;height:100%}
.gpt-grain{position:absolute;inset:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.025}
.gpt-glow{position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:700px;height:320px;border-radius:50%;background:radial-gradient(ellipse at center,rgba(176,110,74,.22) 0%,transparent 70%);pointer-events:none;animation:pulse 4.5s ease infinite}
.gpt-inner{position:relative;z-index:1;padding:100px 48px}
.gpt-fire-badge{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,rgba(176,110,74,.28),rgba(176,110,74,.1));border:1px solid rgba(176,110,74,.38);border-radius:40px;padding:8px 24px;margin-bottom:22px;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--tl)}
.fire{font-size:1rem;animation:floatY 2.5s ease infinite;display:inline-block}
.gpt-sec-lbl{font-size:.64rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(176,110,74,.65);margin-bottom:12px}
.gpt-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,4.5vw,3.8rem);font-weight:700;color:#fff;line-height:1.1;margin-bottom:20px}
.gpt-title em{font-style:italic;color:var(--tl)}
.gpt-sub{font-size:1rem;color:rgba(255,255,255,.5);font-weight:300;max-width:600px;line-height:1.75;margin-bottom:60px}
.gpt-sub strong{color:rgba(255,255,255,.82);font-weight:600}
.gpt-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:56px;align-items:start;margin-bottom:52px}
.gpt-chat-wrap{animation:floatY 5s ease infinite}
.gpt-chat{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:18px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,.45)}
.gpt-chat-bar{background:rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);padding:14px 20px;display:flex;align-items:center;gap:12px}
.gpt-dots{display:flex;gap:6px}
.gpt-dot{width:9px;height:9px;border-radius:50%}
.gpt-dot.r{background:#ff6b6b}.gpt-dot.y{background:#ffd93d}.gpt-dot.g{background:#6bcb77}
.gpt-bar-name{font-size:.72rem;color:rgba(255,255,255,.35);letter-spacing:.05em;flex:1;text-align:center}
.gpt-bar-tag{font-size:.58rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:rgba(176,110,74,.15);color:var(--tl);border-radius:20px;padding:2px 10px}
.gpt-chat-body{padding:22px 20px;display:flex;flex-direction:column;gap:12px}
.gpt-msg{border-radius:12px;padding:14px 18px;font-size:.8rem;line-height:1.65}
.gpt-msg-lbl{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.3);margin-bottom:6px}
.gpt-msg.user{background:rgba(176,110,74,.13);border:1px solid rgba(176,110,74,.2);color:rgba(255,255,255,.72)}
.gpt-msg.ai{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);color:rgba(255,255,255,.72)}
.hl{color:var(--tl);font-weight:600}
.gpt-typing{display:flex;gap:5px;padding:10px 18px}
.gpt-typing span{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.3);animation:pulse 1.3s ease infinite}
.gpt-typing span:nth-child(2){animation-delay:.2s}.gpt-typing span:nth-child(3){animation-delay:.4s}
.gpt-chat-foot{border-top:1px solid rgba(255,255,255,.05);padding:14px 20px;display:flex;align-items:center;gap:12px}
.gpt-input-mock{flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:10px 14px;font-size:.78rem;color:rgba(255,255,255,.22);font-family:'DM Sans',sans-serif}
.gpt-send-btn{width:34px;height:34px;border-radius:8px;background:var(--terra);display:flex;align-items:center;justify-content:center;font-size:.85rem;box-shadow:0 4px 14px rgba(176,110,74,.35)}
.gpt-feats{display:flex;flex-direction:column;gap:16px}
.gpt-feat{display:flex;gap:16px;align-items:flex-start;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:18px;transition:border-color .3s,background .3s}
.gpt-feat:hover{border-color:rgba(176,110,74,.25);background:rgba(176,110,74,.05)}
.gpt-feat-icon{width:40px;height:40px;border-radius:10px;background:rgba(176,110,74,.12);border:1px solid rgba(176,110,74,.2);display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0}
.gpt-feat-title{font-size:.87rem;font-weight:600;color:#fff;margin-bottom:3px}
.gpt-feat-text{font-size:.78rem;color:rgba(255,255,255,.45);line-height:1.6;font-weight:300}
.gpt-bottom{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.gpt-callout{background:linear-gradient(135deg,rgba(176,110,74,.18),rgba(176,110,74,.07));border:1px solid rgba(176,110,74,.28);border-radius:16px;padding:36px;display:flex;flex-direction:column;justify-content:space-between}
.gpt-callout-text{font-family:'Cormorant Garamond',serif;font-size:1.32rem;font-weight:600;color:rgba(255,255,255,.82);line-height:1.55;font-style:italic;margin-bottom:24px}
.gpt-callout-text strong{font-style:normal;color:#fff;font-weight:700}
.gpt-callout-tag{display:inline-flex;align-items:center;gap:8px;font-size:.67rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--tl)}
.gpt-callout-tag::before{content:'';display:block;width:24px;height:1px;background:var(--terra)}
.gpt-incluso{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:36px}
.gpt-incluso-title{font-size:.63rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.32);margin-bottom:22px}
.gpt-incluso-ul{list-style:none;display:flex;flex-direction:column;gap:14px}
.gpt-incluso-ul li{display:flex;align-items:flex-start;gap:12px}
.gpt-bullet{width:22px;height:22px;border-radius:6px;background:rgba(176,110,74,.15);border:1px solid rgba(176,110,74,.25);display:flex;align-items:center;justify-content:center;font-size:.72rem;color:var(--tl);flex-shrink:0;margin-top:2px}
.gpt-incluso-txt{font-size:.83rem;color:rgba(255,255,255,.55);line-height:1.55;font-weight:300}
.gpt-incluso-txt strong{color:rgba(255,255,255,.82);font-weight:600}

/* INVEST */
.inv-section{background:#0e2b30}
.inv-section .section-title{color:#fff}
.inv-section .section-label{color:var(--tl)}
.inv-sub{font-size:.89rem;color:rgba(255,255,255,.4);margin-top:10px;font-weight:300}
.inv-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:52px}
.inv-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;overflow:hidden;transition:border-color .3s}
.inv-card:hover{border-color:rgba(176,110,74,.25)}
.inv-card.feat{border-color:rgba(176,110,74,.3);background:rgba(176,110,74,.06)}
.inv-bar{height:3px}
.inv-bar.c1{background:var(--tl)}.inv-bar.c2{background:var(--terra)}
.inv-body{padding:32px 28px}
.inv-lbl{font-size:.59rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,.32);margin-bottom:8px}
.inv-name{font-size:1rem;font-weight:600;color:#fff;margin-bottom:6px;line-height:1.3}
.inv-meta{font-size:.73rem;color:rgba(255,255,255,.3);margin-bottom:24px;font-weight:300}
.inv-price{font-family:'Cormorant Garamond',serif;font-size:2.7rem;font-weight:700;color:#fff;line-height:1}
.inv-price-note{font-size:.71rem;color:rgba(176,110,74,.8);margin-top:4px;margin-bottom:24px;font-weight:500}
.inv-ul{list-style:none;display:flex;flex-direction:column;gap:9px;border-top:1px solid rgba(255,255,255,.06);padding-top:20px}
.inv-ul li{font-size:.79rem;color:rgba(255,255,255,.5);padding-left:18px;position:relative;line-height:1.55;font-weight:300}
.inv-ul li::before{content:'✓';position:absolute;left:0;color:var(--tl);font-weight:700;font-size:.74rem}
.inv-total{margin-top:36px;background:rgba(176,110,74,.08);border:1px solid rgba(176,110,74,.22);border-radius:14px;padding:32px 36px;display:flex;justify-content:space-between;align-items:center}
.inv-total-lbl{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.32);margin-bottom:8px}
.inv-total-name{font-size:1rem;color:rgba(255,255,255,.7);font-weight:400}
.inv-total-val{font-family:'Cormorant Garamond',serif;font-size:3.1rem;font-weight:700;color:#fff;line-height:1;text-align:right}
.inv-total-sub{font-size:.71rem;color:rgba(255,255,255,.3);margin-top:5px;text-align:right}
.inv-obs{margin-top:24px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:10px;padding:20px 24px;font-size:.77rem;color:rgba(255,255,255,.3);line-height:1.72;font-weight:300}
.inv-obs strong{color:rgba(255,255,255,.48);font-weight:600}

/* POR QUÊ */
.pq-section{background:var(--white)}
.pq-quote{background:var(--ink);border-radius:16px;padding:40px 48px;margin-bottom:64px;position:relative}
.pq-quote::before{content:'"';font-family:'Cormorant Garamond',serif;font-size:8rem;line-height:.7;color:var(--terra);opacity:.18;position:absolute;top:20px;left:36px}
.pq-quote-text{font-size:1.05rem;color:rgba(255,255,255,.72);line-height:1.82;font-weight:300;font-style:italic;position:relative;z-index:1;padding-left:20px}
.metodo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:52px 0}
.metodo-card{background:var(--white);border:1px solid rgba(20,55,60,.07);border-radius:14px;padding:28px 24px;transition:box-shadow .3s,border-color .3s}
.metodo-card:hover{box-shadow:0 8px 24px rgba(20,55,60,.08);border-color:rgba(176,110,74,.2)}
.metodo-num{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:rgba(176,110,74,.2);margin-bottom:12px}
.metodo-title{font-size:.8rem;font-weight:700;color:var(--ink);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}
.metodo-text{font-size:.81rem;color:#4a6a6e;line-height:1.72;font-weight:300}
.founders-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:var(--ink);text-align:center;margin-bottom:40px}
.founders-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.founder-card{background:var(--white);border:1px solid rgba(20,55,60,.07);border-radius:16px;overflow:hidden;display:flex;transition:box-shadow .3s}
.founder-card:hover{box-shadow:0 10px 30px rgba(20,55,60,.09)}
.founder-photo{width:120px;flex-shrink:0;background:linear-gradient(135deg,var(--ink),var(--sage));overflow:hidden}
.founder-photo img{width:100%;height:100%;object-fit:cover;object-position:top;filter:grayscale(20%)}
.founder-info{padding:24px 22px;flex:1}
.founder-name{font-weight:700;font-size:1.03rem;color:var(--ink);margin-bottom:4px}
.founder-role{font-size:.71rem;color:var(--terra);font-weight:600;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px}
.founder-bio{font-size:.78rem;color:#4a6a6e;line-height:1.7;font-weight:300;margin-bottom:14px}
.founder-tags{display:flex;flex-wrap:wrap;gap:6px}
